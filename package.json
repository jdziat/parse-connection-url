{
  "name": "parse-connection-url",
  "homepage": "https://github.com/jdziat/parse-connection-url",
  "author": "Jordan Dziat <jordan@dziat.com> (http://jordandziat.com)",
  "license": "MIT",
  "version": "1.3.4",
  "description": "A Nodejs module that allows you to parse connection strings/objects in a consistent way.",
  "main": "src/index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "src/",
    "index.d.ts",
    "LICENSE",
    "readme.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "release": "semantic-release",
    "docs": "jsdoc --verbose -R ./readme.md -d ./docs/ -t ./node_modules/ink-docstrap/template/ src/index.js src/schema.js"
  },
  "keywords": [
    "http",
    "solr",
    "knex",
    "pg",
    "connection",
    "string",
    "parse",
    "url",
    "postgres",
    "mysql",
    "mongodb",
    "redis",
    "jdbc",
    "odbc"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jdziat/parse-connection-url.git"
  },
  "bugs": {
    "url": "https://github.com/jdziat/parse-connection-url/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.17.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "ink-docstrap": "^1.3.2",
    "jsdoc": "^4.0.5",
    "semantic-release": "^25.0.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
